{
  "version": "1.0",
  "viewport": { "width": 1080, "height": 1350 },
  "account": "@ryo_finance_ai",
  "role_colors": {
    "hook":    "#f0c040",
    "problem": "#e05040",
    "step":    "#f0c040",
    "proof":   "#40c080",
    "cta":     "#f0c040"
  },
  "html_template": "<!DOCTYPE html><html lang=\"ja\"><head><meta charset=\"UTF-8\"><meta name=\"viewport\" content=\"width=1080\"><style>*{margin:0;padding:0;box-sizing:border-box}body{width:1080px;height:1350px;overflow:hidden;font-family:'Hiragino Sans','Hiragino Kaku Gothic ProN','Noto Sans JP',sans-serif;background:linear-gradient(170deg,#080f28 0%,#0a1535 45%,#050910 100%);position:relative;color:#fff}.glow{position:absolute;top:20%;right:-100px;width:500px;height:500px;border-radius:50%;background:radial-gradient(circle,rgba(15,50,120,.25) 0%,transparent 70%);pointer-events:none}.top-lines{position:absolute;top:0;left:0;right:0;padding:0 60px}.top-lines .line1{height:4px;background:linear-gradient(90deg,#f0c040,#c8942a);margin-top:40px}.top-lines .line2{height:1px;background:rgba(240,192,64,.35);margin-top:6px}.slide-num{position:absolute;top:44px;right:60px;font-size:26px;font-weight:700;color:#f0c040;letter-spacing:.05em}.role-bar{position:absolute;top:0;left:0;width:10px;height:100%;background:{{ROLE_COLOR}}}.content{position:absolute;top:160px;left:70px;right:70px;bottom:180px;display:flex;flex-direction:column;justify-content:center;gap:32px}.headline{font-size:80px;font-weight:900;line-height:1.2;color:#fff;text-shadow:3px 3px 0 rgba(0,0,0,.6),0 0 40px rgba(240,192,64,.25);letter-spacing:-.02em}.subtext{font-size:36px;font-weight:700;color:#f0c040;line-height:1.4;letter-spacing:.01em}.divider{width:120px;height:3px;background:linear-gradient(90deg,#f0c040,transparent)}.body-text{font-size:34px;font-weight:500;color:rgba(210,220,245,.9);line-height:1.65}.bottom-bar{position:absolute;bottom:0;left:0;right:0;padding:0 60px 0}.bottom-bar .line1{height:1px;background:rgba(240,192,64,.35)}.bottom-bar .line2{height:3px;background:linear-gradient(90deg,#f0c040,#c8942a);margin-top:5px}.bottom-info{position:absolute;bottom:20px;left:0;right:0;display:flex;justify-content:space-between;align-items:center;padding:0 60px}.account{font-size:26px;font-weight:700;color:rgba(210,220,245,.8);letter-spacing:.06em}.next-hint{font-size:24px;color:#f0c040;font-weight:600}.dots{display:flex;gap:14px;align-items:center}.dot{width:10px;height:10px;border-radius:5px;background:rgba(255,255,255,.25)}.dot.active{width:28px;background:#f0c040}</style></head><body><div class=\"glow\"></div><div class=\"role-bar\"></div><div class=\"top-lines\"><div class=\"line1\"></div><div class=\"line2\"></div></div><div class=\"slide-num\">{{SLIDE_NUM}} / {{TOTAL}}</div><div class=\"content\"><div class=\"headline\">{{HEADLINE}}</div><div class=\"subtext\">{{SUBTEXT}}</div><div class=\"divider\"></div><div class=\"body-text\">{{BODY}}</div></div><div class=\"bottom-bar\"><div class=\"line1\"></div><div class=\"line2\"></div></div><div class=\"bottom-info\"><span class=\"account\">{{ACCOUNT}}</span><span class=\"next-hint\">続きを読む →</span></div><script>const roleColors={hook:'#f0c040',problem:'#e05040',step:'#f0c040',proof:'#40c080',cta:'#f0c040'};const role='{{ROLE}}';const bar=document.querySelector('.role-bar');if(bar)bar.style.background=roleColors[role]||'#f0c040';const dots=document.querySelector('.dots');const total=parseInt('{{TOTAL}}');const current=parseInt('{{SLIDE_NUM}}');if(dots){for(let i=1;i<=total;i++){const d=document.createElement('div');d.className='dot'+(i===current?' active':'');dots.appendChild(d);}}</script></body></html>"
}
